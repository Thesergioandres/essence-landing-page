{
  "name": "essence-backend",
  "version": "1.0.0",
  "description": "Backend API para Essence Landing Page",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node scripts/devStart.js",
    "dev:v2": "nodemon --watch controllers --watch models --watch routes --watch services --watch middleware --watch server.js --watch src --ext js,json --exec \"node src/infrastructure/jobs/devStartV2.job.js\"",
    "dev:no-sync": "nodemon server.js",
    "dev:sync-only": "node scripts/syncProdToLocal.js",
    "dev:sync-v2": "node src/infrastructure/jobs/syncProdToLocalV2.job.js",
    "pretest": "node scripts/validate-test-config.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:clean": "cross-env NODE_ENV=test node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --silent",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --detectOpenHandles --forceExit",
    "check:mongo": "node checkMongoConnection.js",
    "recalc:top1-25": "node recalculateTop1SalesTo25.js",
    "recalc:commissions": "node recalculateTop1SalesTo25.js",
    "recalc:sales-profits": "node scripts/recalculateSalesProfits.js",
    "db:indexes": "node scripts/createIndexes.js",
    "migrate:business-slugs": "node scripts/migrateBusinessSlugs.js"
  },
  "keywords": [
    "express",
    "mongodb",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.66.1",
    "cloudinary": "^1.41.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "ssh2": "^1.17.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.7",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@shelf/jest-mongodb": "^6.0.2",
    "@types/jest": "^29.5.12",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.1",
    "nodemon": "^3.0.1",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.afterEnv.js"
    ],
    "transform": {},
    "injectGlobals": true,
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/calculations.test.js"
    ],
    "testTimeout": 120000
  }
}
